                              "PropertyTypeName": [
                                {
                                  "$type": "UAssetAPI.UnrealTypes.FPropertyTypeNameNode, UAssetAPI",
                                  "Name": "StrProperty",
                                  "InnerCount": 0
                                }
                              ],
                              "PropertyTagExtensions": "NoExtension",
                              "Value": "NOTE FOR ALL NEW TEAM MEMBERS\r\n\r\nResource Acquisition might seem like a simple assignment, but you gotta watch your step round these parts. Woolly aphids can sneak up on you when you least expect it. See a cute blue thing with fur? Step back. They startle easy, and they’ll freeze your foot off.\r\n\r\nThis is what happens when bugs are injected with souped up mint candy, it turns out. And now the brain geniuses at the O.G.R.R. Labs are saying another batch of those frisky little abominations just escaped.\r\n\r\nNow you may be wondering why we’re boosting bugs with candy juice all of a sudden. My man up there says they were throwing stuff at the wall to get a smile from our big boss gal. You know the one.\r\n\r\nAnd you better believe they got the go ahead to do it to bigger, badder critters! So, watch your back. Watch everyone’s backs. They’re bound to lose some of those too eventually."
                            },
                            {
                              "$type": "UAssetAPI.PropertyTypes.Objects.StrPropertyData, UAssetAPI",
                              "Name": "FemaleText",
                              "ArrayIndex": 0,
                              "PropertyGuid": null,
                              "IsZero": false,
